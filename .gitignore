# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# The Canopy Remote portal SPA is a build artifact (npm run build:portal, run by
# tauri's beforeBuildCommand), but keep a committed placeholder index so the
# crate's include_dir!("../portal/dist") still compiles on a fresh checkout.
!portal/dist/
portal/dist/*
!portal/dist/index.html

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Aider local chat history (not part of the project)
.aider.chat.history.md
.aider*

# Sidecar binaries staged by scripts/prepare-sidecar.mjs (built artifacts)
/src-tauri/binaries/

# design-sync: staged scripts, build output, and all sync state/inputs
/.ds-sync/
/ds-bundle/
/.design-sync/
pnpm-lock.yaml
.claude/

# CI-staged ONNX Runtime libraries (bundled as app resources; not committed)
src-tauri/onnxruntime/*.dylib
src-tauri/onnxruntime/*.so
src-tauri/onnxruntime/*.dll
