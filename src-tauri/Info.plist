<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Merged into the app bundle's Info.plist by tauri-build. Without the usage
  string macOS kills the process the moment dictation opens the microphone,
  instead of showing the permission prompt.
-->
<plist version="1.0">
<dict>
	<key>NSMicrophoneUsageDescription</key>
	<string>Canopy uses the microphone for voice dictation. Audio is transcribed locally on this device and never uploaded.</string>
</dict>
</plist>
