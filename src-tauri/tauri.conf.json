{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Canopy",
  "version": "0.1.0",
  "identifier": "app.causeconnect.canopy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run build:hook && npm run dev",
    "beforeBuildCommand": "npm run build:hook:release && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Canopy",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "externalBin": [
      "binaries/canopy-hook"
    ],
    "publisher": "Cause Connect Pte Ltd",
    "copyright": "Copyright 2026 Cause Connect Pte Ltd. All rights reserved.",
    "licenseFile": "../LICENSE.md",
    "shortDescription": "Local-first, memory-light IDE for coding agents",
    "longDescription": "Canopy is a local-first, memory-light IDE built around coding agents and git worktrees. Terminal-first, offline-capable, no Electron.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBNzgwMDkzNjE1MjNGNzMKUldSelAxSmhrd0I0MnFXeDc1MUhINWI1Mm1JTDdiT2RSMnZrSkxvVnVzTHUyb08xc2l1NjN1WkkK",
      "endpoints": [
        "https://github.com/FluidWorksApp/canopy-ide/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}